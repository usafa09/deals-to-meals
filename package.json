{
  "name": "deals-to-meals",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs');let js=fs.readFileSync('public/app.js','utf8');js=js.replace(/\\/\\*[\\s\\S]*?\\*\\//g,'');js=js.replace(/^[ \\t]*\\/\\/[^\\n]*$/gm,'');js=js.replace(/\\n{3,}/g,'\\n\\n');fs.writeFileSync('public/app.min.js',js);let css=fs.readFileSync('public/styles.css','utf8');css=css.replace(/\\/\\*[\\s\\S]*?\\*\\//g,'');css=css.replace(/\\n{3,}/g,'\\n');fs.writeFileSync('public/styles.min.css',css);console.log('Minified JS+CSS');\"",
    "start": "node server.js",
    "test": "node tests/utils.test.js",
    "test:integration": "node tests/integration.test.js",
    "scrape:aldi": "node scrapers/aldi.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.41.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
