{
  "name": "deals-to-meals",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build:js": "npx terser public/app.js -c -m -o public/app.min.js",
    "build:css": "npx csso public/styles.css -o public/styles.min.css",
    "build": "npm run build:js && npm run build:css && echo 'Build complete — minified JS+CSS'",
    "start": "node server.js",
    "test": "node tests/utils.test.js",
    "test:integration": "node tests/integration.test.js",
    "scrape:aldi": "node scrapers/aldi.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.41.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "csso-cli": "^4.0.2",
    "terser": "^5.46.1"
  }
}
